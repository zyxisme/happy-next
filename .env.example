# Happy Next - docker-compose environment
#
# Usage:
# 1) Copy this file to `.env`
# 2) Fill in required values
# 3) Run: `docker-compose up -d`
#
# Notes:
# - Do NOT commit `.env` (it is gitignored)
# - This file is safe to commit: it contains placeholders only
#
# Ports (from docker-compose.yml):
# - Web app (Nginx): http://localhost:3030
# - API server:      http://localhost:3031
# - Voice gateway:   http://localhost:3040
# - MinIO console:   http://localhost:3050

# === Server (happy-server) ===
# Required. Used to sign auth tokens and seed server-side crypto primitives.
# Generate with a password manager or: `openssl rand -hex 32`
HANDY_MASTER_SECRET=changeme-32-bytes-hex

# Optional. Public URL where the web app is served (used in some connect flows).
APP_URL=http://localhost:3030

# === Database (Postgres) ===
POSTGRES_DB=happy
POSTGRES_USER=happy
POSTGRES_PASSWORD=changeme-postgres-password

# === Redis ===
# Optional for docker-compose: Redis runs in-compose and happy-server uses it via service name.
# REDIS_URL=redis://redis:6379

# === S3 / MinIO (happy-server) ===
# Required for uploads/artifacts. MinIO runs in-compose.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme-minio-secret
S3_BUCKET=happy

# Required: must be reachable by *clients* (browser/mobile), not just containers.
# For local compose, MinIO is exposed on port 3050.
S3_PUBLIC_URL=http://localhost:3050

# === GitHub OAuth/App (optional) ===
# Leave empty to disable GitHub integration features.
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Canonical name used by happy-server (alias: GITHUB_REDIRECT_URI).
# Example (local): http://localhost:3031/v1/connect/github/callback
GITHUB_REDIRECT_URL=

GITHUB_WEBHOOK_SECRET=

# Private key PEM as a single line with \n escapes, or mount via other secret manager.
GITHUB_PRIVATE_KEY=

## === Web app (happy-app, served by Nginx) ===
# Self-host uses separate origins (no path reverse proxy).
EXPO_PUBLIC_HAPPY_SERVER_URL=http://localhost:3031
# Voice gateway (happy-voice) base URL the app talks to.
EXPO_PUBLIC_VOICE_BASE_URL=http://localhost:3040

# For docker-compose, the gateway must call happy-server by container DNS, not host localhost.
EXPO_PUBLIC_VOICE_TOOL_BRIDGE_BASE_URL=http://happy-server:3031

# Required if using Happy Voice. App sends this as the x-voice-key header.
VOICE_PUBLIC_KEY=dev-voice-public-key

# Voice provider selection used by the app.
EXPO_PUBLIC_VOICE_PROVIDER=happy-voice

# Optional (used by app features that talk to ElevenLabs directly).
ELEVENLABS_AGENT_ID=

# === Voice gateway (happy-voice) — 火山引擎 AI 音视频互动方案 (2025-06-01, ArkV3) ===
# Volcano runs ASR → Doubao (streaming) → bidirectional TTS server-side; function
# calls are executed client-side. The gateway only mints RTC tokens + StartVoiceChat.

# 火山 RTC — MUST be an "AI agent" type RTC app.
VOLC_RTC_APP_ID=
VOLC_RTC_APP_KEY=

# 火山 OpenAPI signing (IAM access key — StartVoiceChat / StopVoiceChat)
VOLC_ACCESS_KEY_ID=
VOLC_SECRET_ACCESS_KEY=
VOLC_RTC_REGION=cn-north-1
VOLC_RTC_API_VERSION=2025-06-01

# LLM (Doubao via built-in ArkV3, runs inside Volcano)
DOUBAO_MODEL=doubao-seed-2-0-lite-260428
LLM_THINKING_TYPE=disabled

# ASR (seed big-model streaming; auth bound to the agent RTC app)
VOLC_ASR_RESOURCE_ID=volc.seedasr.sauc.duration

# Unified voice/speaker — used by BOTH the live agent TTS and message-playback TTS.
VOLC_TTS_VOICE=zh_female_vv_uranus_bigtts

# Agent TTS (bidirectional streaming for the live conversation)
VOLC_AGENT_TTS_RESOURCE_ID=seed-tts-1.0

# Message-playback TTS (streamed, sentence-by-sentence; speech-console TTS app)
VOLC_TTS_APP_ID=
VOLC_TTS_TOKEN=
VOLC_TTS_CLUSTER=volcano_tts
# Pre-TTS cleaning (strip markdown/code/links). LLM cleaning needs ARK_API_KEY;
# otherwise falls back to regex. Streamed so playback starts on the first sentence.
ARK_API_KEY=
TTS_CLEAN_LLM=true
TTS_CLEAN_MODEL=doubao-seed-2-0-lite-260428

# 可用 | 分隔多个，每次进房随机选一条。例：你好，需要我做点什么？|在的，说吧|我在听
AGENT_WELCOME_MESSAGE=你好，需要我做点什么？
DEFAULT_LANGUAGE=zh
