# ============================================================================
# happy-voice — 火山引擎 AI 音视频互动方案(2025-06-01, ArkV3 内置豆包)语音网关
# 复制为 .env.local 后填写。生产经 deploy/.env 注入。
# ============================================================================

# —— 服务 ——
HOST=0.0.0.0
PORT=3045
NODE_ENV=development

# App 调用网关的鉴权 key(App 的 x-voice-key)
VOICE_PUBLIC_KEY=dev-voice-public-key

# —— 火山 RTC(必须是「AI 智能体」类型的应用)——
VOLC_RTC_APP_ID=
VOLC_RTC_APP_KEY=

# —— 火山 OpenAPI 签名(IAM 访问密钥,StartVoiceChat/StopVoiceChat)——
VOLC_ACCESS_KEY_ID=
VOLC_SECRET_ACCESS_KEY=
VOLC_RTC_REGION=cn-north-1
VOLC_RTC_API_VERSION=2025-06-01
RTC_TOKEN_TTL_SECONDS=86400

# —— ASR(seed 大模型流式;鉴权绑定在 agent app 上,无需单独 token)——
VOLC_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
VOLC_ASR_STREAM_MODE=2
VOLC_ASR_SILENCE_MS=600

# —— LLM(豆包,内置 ArkV3,火山机房内流式)——
DOUBAO_MODEL=doubao-seed-2-0-lite-260215
LLM_THINKING_TYPE=disabled
LLM_HISTORY_LENGTH=10
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.3
LLM_MAX_TOKENS=1024

# —— 统一音色(实时对话 + 朗读消息共用)——
VOLC_TTS_VOICE=zh_female_vv_mars_bigtts

# —— Agent TTS(双向流式,用于实时对话)——
VOLC_AGENT_TTS_RESOURCE_ID=seed-tts-1.0

# —— 消息朗读 TTS(App「朗读消息」功能,流式按句合成)——
VOLC_TTS_APP_ID=
VOLC_TTS_TOKEN=
VOLC_TTS_CLUSTER=volcano_tts
# 朗读前的文本清洗(去 markdown/代码/链接)。LLM 清洗需 ARK_API_KEY;关掉则用正则。
ARK_API_KEY=
TTS_CLEAN_LLM=true
TTS_CLEAN_MODEL=doubao-seed-2-0-lite-260215

# —— 默认语言 / 欢迎语 ——
DEFAULT_LANGUAGE=zh
AGENT_WELCOME_MESSAGE=你好，需要我做点什么？

# —— Prompt 模板 ——
PROMPT_VOICE_AGENT_FILE=prompts/voice-agent.system.txt
