{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_ENV": "development",
        "ABI_FILTERS": "arm64-v8a"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2"
      }
    },
    "development-store": {
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "store",
      "channel": "development",
      "env": {
        "APP_ENV": "development",
        "ABI_FILTERS": "arm64-v8a"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2"
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview",
        "ABI_FILTERS": "arm64-v8a"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2"
      }
    },
    "preview-store": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview",
        "ABI_FILTERS": "arm64-v8a"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_ENV": "production",
        "ABI_FILTERS": "arm64-v8a"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "service@hitosea.com",
        "ascAppId": "6758196715",
        "appleTeamId": "G365J5PZA2"
      }
    }
  }
}
